DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DATABASE_ENGINE=mysql
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_PASSWORD_RESET_TIMEOUT=3600
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=2097152

MYSQL_DATABASE=rozledger
MYSQL_USER=rozledger_user
MYSQL_PASSWORD=change-this-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
