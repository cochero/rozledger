DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-ubuntu-server-ip,rozledger.in,www.rozledger.in,rozledger.com,www.rozledger.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://your-ubuntu-server-ip:8000,https://rozledger.in,https://www.rozledger.in,https://rozledger.com,https://www.rozledger.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_DATABASE_ENGINE=mysql
ROZLEDGER_PUBLIC_URL=https://rozledger.in
ROZLEDGER_HOST_PORT=18080

MYSQL_DATABASE=rozledger
MYSQL_USER=rozledger_user
MYSQL_PASSWORD=change-this-password
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_HOST=mysql
MYSQL_PORT=3306

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=cs@rozledger.in
DJANGO_EMAIL_HOST_PASSWORD=change-this-email-password
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_DEFAULT_FROM_EMAIL=RozLedger <cs@rozledger.in>
ROZLEDGER_NOTIFY_EMAIL=cs@rozledger.in
